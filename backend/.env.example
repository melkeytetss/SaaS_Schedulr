# Backend secrets (Edge Functions + admin scripts).
# Copy to .env.local and fill in your values.

# Supabase project settings (from `supabase start` locally, or your project dashboard).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email provider for send-booking-email / send-reminder functions.
RESEND_API_KEY=

# Stripe (future billing).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Calendar integration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
